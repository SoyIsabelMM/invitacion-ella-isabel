# Base URL of the RSVP backend API. When set, the form will persist RSVPs to MongoDB before sending emails.
# Example (local): http://localhost:3001
# Leave empty to only use EmailJS (no backend persistence).
NEXT_PUBLIC_RSVP_API_URL=

# Feature flag for email sending. Set to "true" or "1" to send notification and auto-reply emails via EmailJS; leave empty or "false" to skip emails.
NEXT_PUBLIC_SEND_EMAILS=

# EmailJS (only used when NEXT_PUBLIC_SEND_EMAILS=true). Get Service ID, Template IDs and Public Key from https://dashboard.emailjs.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_AUTO_REPLY_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Organizer emails for RSVP notifications (to and cc). Fill with real addresses; do not commit .env.
NEXT_PUBLIC_RSVP_ORGANIZER_TO_EMAIL=
NEXT_PUBLIC_RSVP_ORGANIZER_CC_EMAIL=

# Event details (used in emails and Google Calendar link). Optional; defaults are used if empty.
NEXT_PUBLIC_RSVP_EVENT_NAME=
NEXT_PUBLIC_RSVP_EVENT_DATE=
NEXT_PUBLIC_RSVP_EVENT_TIME=
NEXT_PUBLIC_RSVP_EVENT_LOCATION=
